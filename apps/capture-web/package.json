{
  "name": "@phenometric/capture-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 4173 --strictPort",
    "build": "node scripts/generate-asset-manifest.mjs && vite build",
    "demo:smoke": "pnpm test:browser",
    "verify:assets": "node scripts/generate-asset-manifest.mjs --check",
    "test:unit": "vitest run",
    "test:browser": "vite build && playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "0.10.35",
    "@phenometric/ambient-core": "workspace:*",
    "@phenometric/contracts": "workspace:*",
    "@phenometric/evidence-core": "workspace:*",
    "@phenometric/event-log": "workspace:*",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "22.20.0",
    "tsx": "4.20.6",
    "typescript": "5.6.3",
    "vite": "8.1.5",
    "vitest": "2.1.4"
  }
}
